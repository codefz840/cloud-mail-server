# cloud-mail-server .env configuration example
# Copy this file to .env and fill in your values

# URL of your cloud-mail worker (e.g. https://mail.example.com)
CLOUD_MAIL_URL=https://your-cloud-mail-worker.workers.dev

# IMAP server port (default: 143)
IMAP_PORT=143

# SMTP server port (default: 587)
SMTP_PORT=587

# Host to bind the servers (default: 0.0.0.0)
HOST=0.0.0.0
